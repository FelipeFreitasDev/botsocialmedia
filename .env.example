# Copie este arquivo para .env e preencha suas chaves
# OPENAI: Geração de imagens DALL-E e geração de texto
OPENAI_API_KEY=your-openai-api-key

# HUGGING FACE: Modelos de IA para geração de imagens (opcional)
HUGGINGFACE_API_KEY=your-huggingface-api-key

# STABILITY AI: Geração de imagens (opcional)
STABILITY_API_KEY=your-stability-api-key

# Porta do servidor
PORT=3000
